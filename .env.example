# Resend Email API Configuration
# Get your API key from https://resend.com/api-keys

# Required: Your Resend API key
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Optional: The sender email address (default: YourBrand <onboarding@resend.dev>)
# VITE_RESEND_FROM_EMAIL=YourBrand <onboarding@resend.dev>

# Required: The business owner email that receives inquiries
VITE_RESEND_TO_EMAIL=your-email@example.com

# Optional: Custom API URL for serverless function (if using custom domain)
# VITE_API_URL=https://your-site.netlify.app

# Admin password for managing reviews
# ADMIN_PASSWORD=admin123
